#!/bin/sh
# Configure script for rochambeau (rps)

# Default values
: ${CC:=gcc}
: ${CFLAGS:="-O2 -Wall"}
: ${LDFLAGS:=""}
: ${prefix:=/usr/local}
: ${bindir:="${prefix}/bin"}

# Parse command line
for arg in "$@"; do
  case $arg in
    --prefix=*)
      prefix="${arg#--prefix=}"
      bindir="${prefix}/bin"
      ;;
    --bindir=*)
      bindir="${arg#--bindir=}"
      ;;
    --enable-debug)
      CFLAGS="-g -O0 -Wall"
      ;;
    --disable-optimization)
      CFLAGS="-O0 -Wall"
      ;;
    --help)
      echo "Usage: ./configure [OPTIONS]"
      echo ""
      echo "Options:"
      echo "  --prefix=PATH    Installation prefix (default: /usr/local)"
      echo "  --bindir=PATH    Binary directory (default: \$prefix/bin)"
      echo "  --enable-debug   Enable debug build (-g -O0)"
      echo "  --disable-optimization  Disable optimization (-O0)"
      echo "  --help           Show this help"
      echo ""
      echo "Environment variables: CC, CFLAGS, LDFLAGS"
      exit 0
      ;;
  esac
done

# Detect compiler if gcc not found
if ! command -v $CC >/dev/null 2>&1; then
  if command -v cc >/dev/null 2>&1; then
    CC=cc
  else
    echo "Error: No C compiler found (tried gcc, cc)" >&2
    exit 1
  fi
fi

# Verify compiler works
if ! $CC -x c -c -o /dev/null /dev/null 2>/dev/null; then
  echo "Error: $CC cannot compile" >&2
  exit 1
fi

# Create config.mk for Makefile
cat > config.mk << EOF
# Generated by configure - do not edit
CC = $CC
CFLAGS = $CFLAGS
LDFLAGS = $LDFLAGS
prefix = $prefix
bindir = $bindir
EOF

echo "Configuration:"
echo "  CC       = $CC"
echo "  CFLAGS   = $CFLAGS"
echo "  LDFLAGS  = $LDFLAGS"
echo "  prefix   = $prefix"
echo "  bindir   = $bindir"
echo ""
echo "Run 'make' to build."
